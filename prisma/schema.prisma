generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Category {
  food
  transport
  housing
  entertainment
  health
  work
  subscriptions
  shopping
  education
  other
}

enum TransactionType {
  expense
  income
}

enum AccountType {
  checking
  cash
  deposit
  credit_card
}

enum LiabilityType {
  loan
  mortgage
  credit_card
  other
}

model User {
  id           String      @id @default(cuid())
  email        String      @unique
  password     String
  name         String?
  createdAt    DateTime    @default(now())
  transactions Transaction[]
  accounts     Account[]
  liabilities  Liability[]
  settings     Settings?
}

model Account {
  id           String        @id @default(cuid())
  name         String
  type         AccountType
  balance      Float         @default(0)
  currency     String        @default("AZN")
  color        String?
  userId       String
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions Transaction[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

model Liability {
  id             String        @id @default(cuid())
  name           String
  type           LiabilityType
  totalAmount    Float
  remaining      Float
  currency       String        @default("AZN")
  monthlyPayment Float?
  interestRate   Float?
  userId         String
  user           User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
}

model Transaction {
  id          String          @id @default(cuid())
  amount      Float
  currency    String          @default("AZN")
  category    Category
  description String
  date        DateTime
  type        TransactionType
  userId      String
  user        User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  accountId   String?
  account     Account?        @relation(fields: [accountId], references: [id], onDelete: SetNull)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
}

model Settings {
  id            String   @id @default(cuid())
  monthlyBudget Float    @default(1500)
  currency      String   @default("AZN")
  theme         String   @default("system")
  userId        String   @unique
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model AICorrection {
  id              String   @id @default(cuid())
  originalText    String
  aiResult        Json
  correctedResult Json
  createdAt       DateTime @default(now())
}
